  n5 [fillcolor="#ffadad", label="scc 13 | [5] %7 = load double, ptr %6, align 8, !tbaa !5"];
  n4 [fillcolor="#bdb2ff", label="scc 14 | [4] %6 = getelementptr inbounds double, ptr %0, i64 %.0"];
