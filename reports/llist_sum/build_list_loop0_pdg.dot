digraph "build_list:0" {
  rankdir=TB;
  node [shape=box, style="filled,rounded", fontname="monospace", fontsize=10];
  edge [fontname="monospace", fontsize=8];
  subgraph cluster_scc0 {
    label="SCC 0 (cyclic, 6 insts)";
    style="rounded,dashed"; color=gray50;
    n7 [fillcolor="#ffd6a5", label="scc 0 | [7] %7 = getelementptr inbounds %struct.Node, ptr %5, i32 0, i32 1"];
    n6 [fillcolor="#ffd6a5", label="scc 0 | [6] store i64 %.0, ptr %6, align 8, !tbaa !5"];
    n5 [fillcolor="#ffd6a5", label="scc 0 | [5] %6 = getelementptr inbounds %struct.Node, ptr %5, i32 0, i32 0"];
    n4 [fillcolor="#ffd6a5", label="scc 0 | [4] %5 = call ptr @malloc(i64 noundef 16) #6"];
    n8 [fillcolor="#ffd6a5", label="scc 0 | [8] store ptr %.01, ptr %7, align 8, !tbaa !11"];
    n0 [fillcolor="#ffd6a5", label="scc 0 | [0] %.01 = phi ptr [ null, %1 ], [ %5, %4 ]"];
  }
  n3 [fillcolor="#a0c4ff", label="scc 1 | [3] br i1 %3, label %4, label %9"];
  n2 [fillcolor="#caffbf", label="scc 2 | [2] %3 = icmp sgt i64 %.0, 0"];
  subgraph cluster_scc3 {
    label="SCC 3 (cyclic, 2 insts)";
    style="rounded,dashed"; color=gray50;
    n9 [fillcolor="#ffadad", label="scc 3 | [9] %8 = add nsw i64 %.0, -1"];
    n1 [fillcolor="#ffadad", label="scc 3 | [1] %.0 = phi i64 [ %0, %1 ], [ %8, %4 ]"];
  }
  n10 [fillcolor="#bdb2ff", label="scc 4 | [10] br label %2, !llvm.loop !12"];
  n0 -> n8 [color="black", label="data"];
  n1 -> n9 [color="black", label="data"];
  n1 -> n6 [color="black", label="data"];
  n1 -> n2 [color="black", label="data"];
  n2 -> n3 [color="black", label="data"];
  n3 -> n4 [color="blue", label="ctrl"];
  n3 -> n5 [color="blue", label="ctrl"];
  n3 -> n6 [color="blue", label="ctrl"];
  n3 -> n7 [color="blue", label="ctrl"];
  n3 -> n8 [color="blue", label="ctrl"];
  n3 -> n9 [color="blue", label="ctrl"];
  n3 -> n10 [color="blue", label="ctrl"];
  n4 -> n0 [color="black", label="data*", style=dashed];
  n4 -> n5 [color="black", label="data"];
  n4 -> n7 [color="black", label="data"];
  n4 -> n6 [color="red", label="mem"];
  n4 -> n8 [color="red", label="mem"];
  n5 -> n6 [color="black", label="data"];
  n6 -> n4 [color="red", label="mem"];
  n6 -> n6 [color="red", label="mem*", style=dashed];
  n7 -> n8 [color="black", label="data"];
  n8 -> n4 [color="red", label="mem"];
  n8 -> n8 [color="red", label="mem*", style=dashed];
  n9 -> n1 [color="black", label="data*", style=dashed];
}
