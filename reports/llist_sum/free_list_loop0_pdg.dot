digraph "free_list:0" {
  rankdir=TB;
  node [shape=box, style="filled,rounded", fontname="monospace", fontsize=10];
  edge [fontname="monospace", fontsize=8];
  n2 [fillcolor="#ffd6a5", label="scc 0 | [2] br i1 %3, label %4, label %7"];
  n1 [fillcolor="#a0c4ff", label="scc 1 | [1] %3 = icmp ne ptr %.0, null"];
  subgraph cluster_scc2 {
    label="SCC 2 (cyclic, 4 insts)";
    style="rounded,dashed"; color=gray50;
    n3 [fillcolor="#caffbf", label="scc 2 | [3] %5 = getelementptr inbounds %struct.Node, ptr %.0, i32 0, i32 1"];
    n4 [fillcolor="#caffbf", label="scc 2 | [4] %6 = load ptr, ptr %5, align 8, !tbaa !5"];
    n5 [fillcolor="#caffbf", label="scc 2 | [5] call void @free(ptr noundef %.0)"];
    n0 [fillcolor="#caffbf", label="scc 2 | [0] %.0 = phi ptr [ %0, %1 ], [ %6, %4 ]"];
  }
  n6 [fillcolor="#ffadad", label="scc 3 | [6] br label %2, !llvm.loop !11"];
  n0 -> n5 [color="black", label="data"];
  n0 -> n3 [color="black", label="data"];
  n0 -> n1 [color="black", label="data"];
  n1 -> n2 [color="black", label="data"];
  n2 -> n3 [color="blue", label="ctrl"];
  n2 -> n4 [color="blue", label="ctrl"];
  n2 -> n5 [color="blue", label="ctrl"];
  n2 -> n6 [color="blue", label="ctrl"];
  n3 -> n4 [color="black", label="data"];
  n4 -> n0 [color="black", label="data*", style=dashed];
  n4 -> n5 [color="red", label="mem"];
  n5 -> n4 [color="red", label="mem"];
}
