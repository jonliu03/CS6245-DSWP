    n1 [fillcolor="#9bf6ff", label="scc 6 | [1] %.0 = phi i32 [ 0, %22 ], [ %33, %28 ]"];
  }
  n9 [fillcolor="#ffc6ff", label="scc 7 | [9] br label %26, !llvm.loop !16"];
  n0 -> n7 [color="black", label="data"];
  n1 -> n8 [color="black", label="data"];
