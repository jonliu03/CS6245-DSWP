digraph "histogram:0" {
  rankdir=TB;
  node [shape=box, style="filled,rounded", fontname="monospace", fontsize=10];
  edge [fontname="monospace", fontsize=8];
  subgraph cluster_scc0 {
    label="SCC 0 (cyclic, 3 insts)";
    style="rounded,dashed"; color=gray50;
    n9 [fillcolor="#ffd6a5", label="scc 0 | [9] %13 = add nsw i64 %12, 1"];
    n8 [fillcolor="#ffd6a5", label="scc 0 | [8] %12 = load i64, ptr %11, align 8, !tbaa !9"];
    n10 [fillcolor="#ffd6a5", label="scc 0 | [10] store i64 %13, ptr %11, align 8, !tbaa !9"];
  }
  n7 [fillcolor="#a0c4ff", label="scc 1 | [7] %11 = getelementptr inbounds i64, ptr %2, i64 %10"];
  n6 [fillcolor="#caffbf", label="scc 2 | [6] %10 = sext i32 %9 to i64"];
  n5 [fillcolor="#ffadad", label="scc 3 | [5] %9 = and i32 %8, 255"];
  n4 [fillcolor="#bdb2ff", label="scc 4 | [4] %8 = load i32, ptr %7, align 4, !tbaa !5"];
  n3 [fillcolor="#fdffb6", label="scc 5 | [3] %7 = getelementptr inbounds i32, ptr %0, i64 %.0"];
  n2 [fillcolor="#9bf6ff", label="scc 6 | [2] br i1 %5, label %6, label %15"];
  n1 [fillcolor="#ffc6ff", label="scc 7 | [1] %5 = icmp slt i64 %.0, %1"];
  subgraph cluster_scc8 {
    label="SCC 8 (cyclic, 2 insts)";
    style="rounded,dashed"; color=gray50;
    n11 [fillcolor="#e2f0cb", label="scc 8 | [11] %14 = add nsw i64 %.0, 1"];
    n0 [fillcolor="#e2f0cb", label="scc 8 | [0] %.0 = phi i64 [ 0, %3 ], [ %14, %6 ]"];
  }
  n12 [fillcolor="#d3d3d3", label="scc 9 | [12] br label %4, !llvm.loop !11"];
  n0 -> n11 [color="black", label="data"];
  n0 -> n3 [color="black", label="data"];
  n0 -> n1 [color="black", label="data"];
  n1 -> n2 [color="black", label="data"];
  n2 -> n3 [color="blue", label="ctrl"];
  n2 -> n4 [color="blue", label="ctrl"];
  n2 -> n5 [color="blue", label="ctrl"];
  n2 -> n6 [color="blue", label="ctrl"];
  n2 -> n7 [color="blue", label="ctrl"];
  n2 -> n8 [color="blue", label="ctrl"];
  n2 -> n9 [color="blue", label="ctrl"];
  n2 -> n10 [color="blue", label="ctrl"];
  n2 -> n11 [color="blue", label="ctrl"];
  n2 -> n12 [color="blue", label="ctrl"];
  n3 -> n4 [color="black", label="data"];
  n4 -> n5 [color="black", label="data"];
  n5 -> n6 [color="black", label="data"];
  n6 -> n7 [color="black", label="data"];
  n7 -> n10 [color="black", label="data"];
  n7 -> n8 [color="black", label="data"];
  n8 -> n9 [color="black", label="data"];
  n8 -> n10 [color="red", label="mem"];
  n9 -> n10 [color="black", label="data"];
  n10 -> n8 [color="red", label="mem"];
  n10 -> n10 [color="red", label="mem*", style=dashed];
  n11 -> n0 [color="black", label="data*", style=dashed];
}
