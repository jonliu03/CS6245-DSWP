digraph "sum_heavy:0" {
  rankdir=TB;
  node [shape=box, style="filled,rounded", fontname="monospace", fontsize=10];
  edge [fontname="monospace", fontsize=8];
  subgraph cluster_scc0 {
    label="SCC 0 (cyclic, 2 insts)";
    style="rounded,dashed"; color=gray50;
    n11 [fillcolor="#ffd6a5", label="scc 0 | [11] %12 = fadd double %.01, %11"];
    n0 [fillcolor="#ffd6a5", label="scc 0 | [0] %.01 = phi double [ 0.000000e+00, %1 ], [ %12, %4 ]"];
  }
  n10 [fillcolor="#a0c4ff", label="scc 1 | [10] %11 = call double @heavy_e(double noundef %10) #7"];
  n9 [fillcolor="#caffbf", label="scc 2 | [9] %10 = call double @heavy_d(double noundef %9) #7"];
  n8 [fillcolor="#ffadad", label="scc 3 | [8] %9 = call double @heavy_c(double noundef %8) #7"];
  n7 [fillcolor="#bdb2ff", label="scc 4 | [7] %8 = call double @heavy_b(double noundef %7) #7"];
  n6 [fillcolor="#fdffb6", label="scc 5 | [6] %7 = call double @heavy_a(double noundef %6) #7"];
  n5 [fillcolor="#9bf6ff", label="scc 6 | [5] %6 = load double, ptr %5, align 8, !tbaa !5"];
  n4 [fillcolor="#ffc6ff", label="scc 7 | [4] %5 = getelementptr inbounds %struct.Node, ptr %.0, i32 0, i32 0"];
  n3 [fillcolor="#e2f0cb", label="scc 8 | [3] br i1 %3, label %4, label %15"];
  n2 [fillcolor="#d3d3d3", label="scc 9 | [2] %3 = icmp ne ptr %.0, null"];
  subgraph cluster_scc10 {
    label="SCC 10 (cyclic, 3 insts)";
    style="rounded,dashed"; color=gray50;
    n13 [fillcolor="#ffd6a5", label="scc 10 | [13] %14 = load ptr, ptr %13, align 8, !tbaa !11"];
    n12 [fillcolor="#ffd6a5", label="scc 10 | [12] %13 = getelementptr inbounds %struct.Node, ptr %.0, i32 0, i32 1"];
    n1 [fillcolor="#ffd6a5", label="scc 10 | [1] %.0 = phi ptr [ %0, %1 ], [ %14, %4 ]"];
  }
  n14 [fillcolor="#a0c4ff", label="scc 11 | [14] br label %2, !llvm.loop !12"];
  n0 -> n11 [color="black", label="data"];
  n1 -> n12 [color="black", label="data"];
  n1 -> n4 [color="black", label="data"];
  n1 -> n2 [color="black", label="data"];
  n2 -> n3 [color="black", label="data"];
  n3 -> n4 [color="blue", label="ctrl"];
  n3 -> n5 [color="blue", label="ctrl"];
  n3 -> n6 [color="blue", label="ctrl"];
  n3 -> n7 [color="blue", label="ctrl"];
  n3 -> n8 [color="blue", label="ctrl"];
  n3 -> n9 [color="blue", label="ctrl"];
  n3 -> n10 [color="blue", label="ctrl"];
  n3 -> n11 [color="blue", label="ctrl"];
  n3 -> n12 [color="blue", label="ctrl"];
  n3 -> n13 [color="blue", label="ctrl"];
  n3 -> n14 [color="blue", label="ctrl"];
  n4 -> n5 [color="black", label="data"];
  n5 -> n6 [color="black", label="data"];
  n6 -> n7 [color="black", label="data"];
  n7 -> n8 [color="black", label="data"];
  n8 -> n9 [color="black", label="data"];
  n9 -> n10 [color="black", label="data"];
  n10 -> n11 [color="black", label="data"];
  n11 -> n0 [color="black", label="data*", style=dashed];
  n12 -> n13 [color="black", label="data"];
  n13 -> n1 [color="black", label="data*", style=dashed];
}
