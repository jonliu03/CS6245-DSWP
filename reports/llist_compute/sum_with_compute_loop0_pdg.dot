    n1 [fillcolor="#d3d3d3", label="scc 9 | [1] %.0 = phi ptr [ %0, %1 ], [ %13, %4 ]"];
  }
  n13 [fillcolor="#ffd6a5", label="scc 10 | [13] br label %2, !llvm.loop !12"];
  n0 -> n10 [color="black", label="data"];
